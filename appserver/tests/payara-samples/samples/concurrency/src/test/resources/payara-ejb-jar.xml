<!DOCTYPE payara-ejb-jar PUBLIC "-//Payara.fish// DTD Payara Application Server 7 EJB 4.0//EN" "https://docs.payara.fish/schemas/payara-ejb-jar_4_0-0.dtd">
<payara-ejb-jar>
    <enterprise-beans>
        <ejb>
            <ejb-name>ManagedExecutorDefinitionEJBFromConfig</ejb-name>
            <managed-executor>
                <name>java:app/jakartaee/EJBExecutor</name>
                <max-async>2</max-async>
                <hung-task-threshold>120000</hung-task-threshold>
            </managed-executor>
        </ejb>
    </enterprise-beans>
</payara-ejb-jar>
