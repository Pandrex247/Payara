<!DOCTYPE payara-ejb-jar PUBLIC "-//Payara.fish// DTD Payara Application Server 7 EJB 4.0//EN" "https://docs.payara.fish/schemas/payara-ejb-jar_4_0-0.dtd">
<payara-ejb-jar>
    <enterprise-beans>
        <ejb>
            <ejb-name>ContextServiceEJBFromConfig</ejb-name>
            <context-service>
                <name>java:global/concurrent/ContextE</name>
                <cleared>IntContext</cleared>
                <propagated>Application</propagated>
                <propagated>IntContextProvider</propagated>
                <unchanged>Transaction</unchanged>
            </context-service>
        </ejb>
    </enterprise-beans>
</payara-ejb-jar>
